# Server
PORT=8000

# Neon Postgres — the food logger touches ONLY the food_log schema (PLAN working agreement)
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname

# Static bearer token — any long random string; the PWA stores it after a
# one-time entry screen. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# USDA FoodData Central (Phase 1+): https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=

# Anthropic (Phase 5 AI plate estimation): https://console.anthropic.com
ANTHROPIC_API_KEY=
# Vision model for plate estimation — fast Haiku-class by default; override if desired
# ESTIMATE_MODEL=claude-haiku-4-5-20251001
